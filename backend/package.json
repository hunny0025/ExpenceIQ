{
  "name": "expenseiq-backend",
  "version": "1.0.0",
  "description": "ExpenseIQ REST API — Node.js + Express + MongoDB",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --verbose --forceExit --detectOpenHandles --passWithNoTests",
    "test:coverage": "jest --coverage --forceExit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "seed": "node src/utils/seeder.js"
  },
  "keywords": [
    "expense",
    "tracker",
    "api",
    "express",
    "mongodb"
  ],
  "author": "Team ExpenseIQ",
  "license": "MIT",
  "dependencies": {
    "@sentry/node": "^10.50.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "joi": "^18.1.2",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0",
    "morgan": "^1.10.0",
    "pdfkit": "^0.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "eslint": "^9.39.4",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.8.3",
    "supertest": "^7.0.0"
  }
}
