# ===========================
# Server Configuration
# ===========================
NODE_ENV=development
PORT=5000

# ===========================
# MongoDB Atlas
# ===========================
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/expenseiq?retryWrites=true&w=majority

# ===========================
# JWT Authentication
# ===========================
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d

# ===========================
# Rate Limiting
# ===========================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
